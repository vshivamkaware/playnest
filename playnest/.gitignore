# ─────────────────────────────────────────────
# PlayNest .gitignore
# ─────────────────────────────────────────────

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild)
ios/
android/
.kotlin/

# Build artifacts
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Environment variables (NEVER commit)
.env
.env.local
.env*.local

# TypeScript
*.tsbuildinfo

# IDE
.idea/
*.swp
*.swo
