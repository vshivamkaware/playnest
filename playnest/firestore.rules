rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────

    /// Returns true if the current user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns true if the current user is the document owner.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Returns true if the current user is an admin.
    /// Admin is determined by:
    ///   1. The hardcoded system admin email (bootstrap admin)
    ///   2. The `isAdmin` flag on the user document
    ///   3. The `role` field set to 'admin' on the user document
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@sv.in' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'))
      );
    }

    /// Returns true if the incoming data does NOT attempt to modify
    /// any of the protected privilege fields.
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role', 'banned', 'isBanned']);
    }

    // ─────────────────────────────────────────────────────────────
    // USERS COLLECTION
    // Each document represents a registered user with their
    // device binding, admin status, and purchased videos.
    //
    // Document ID: Firebase Auth UID
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {

      // READ: Users can read their own document. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();

      // CREATE: Users can only create their own document.
      // Privilege fields (isAdmin, role) can only be set by the
      // system admin email during bootstrap or by existing admins.
      allow create: if isOwner(userId) &&
        (!request.resource.data.keys().hasAny(['isAdmin', 'role']) ||
         isAdmin() ||
         request.auth.token.email == 'admin@sv.in');

      // UPDATE: Users can update their own document but cannot
      // escalate privileges. Admins can update any document.
      allow update: if isAdmin() ||
        (isOwner(userId) && noPrivilegeEscalation());

      // DELETE: Only admins can delete user documents.
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // VIDEOS COLLECTION
    // Each document represents a video with metadata, Google Drive
    // link, category, pricing, and visibility status.
    //
    // Document ID: Auto-generated
    // ─────────────────────────────────────────────────────────────
    match /videos/{videoId} {

      // READ: Admins can read all videos (including hidden).
      //        Users can only read videos that are NOT hidden.
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.get('isHidden', false) == false);

      // WRITE: Only admins can create, update, or delete videos.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // PAYMENT REQUESTS COLLECTION
    // Each document represents a user's payment submission for a
    // premium video, pending admin approval.
    //
    // Document ID: Auto-generated
    // ─────────────────────────────────────────────────────────────
    match /paymentRequests/{requestId} {

      // CREATE: Users can create a payment request only for themselves.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // READ: Users can read their own requests. Admins can read all.
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || isAdmin());

      // UPDATE: Only admins can approve or reject payment requests.
      allow update: if isAdmin();

      // DELETE: Only admins can delete payment requests.
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // SETTINGS COLLECTION
    // App-wide configuration managed by admins.
    // Currently stores: payment UPI ID.
    //
    // Documents: 'payment' (adminUpiId)
    // ─────────────────────────────────────────────────────────────
    match /settings/{docId} {

      // READ: Any authenticated user can read settings
      //        (needed to display UPI ID on payment screen).
      allow read: if isAuthenticated();

      // WRITE: Only admins can modify settings.
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // CATEGORIES COLLECTION (Future)
    // Stores video categories with ordering.
    //
    // Document ID: Auto-generated
    // ─────────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // WATCH HISTORY COLLECTION (Future)
    // Tracks user watch progress for "Continue Watching" feature.
    //
    // Path: watchHistory/{userId}/videos/{videoId}
    // ─────────────────────────────────────────────────────────────
    match /watchHistory/{userId}/videos/{videoId} {
      allow read, write: if isOwner(userId);
    }

    // ─────────────────────────────────────────────────────────────
    // FAVORITES COLLECTION (Future)
    // Stores user's favorited/bookmarked videos.
    //
    // Path: favorites/{userId}/videos/{videoId}
    // ─────────────────────────────────────────────────────────────
    match /favorites/{userId}/videos/{videoId} {
      allow read, write: if isOwner(userId);
    }
  }
}
